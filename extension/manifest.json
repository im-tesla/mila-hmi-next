{
  "manifest_version": 3,
  "name": "mila-hmi-helper",
  "version": "1.0",
  "permissions": ["declarativeNetRequest", "cookies", "alarms"],
  "host_permissions": [
    "*://*/*",
    "http://localhost:3000/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["detect.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["cookies.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtube.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["netflix.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
  ]
}
